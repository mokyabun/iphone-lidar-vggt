# Committed non-secret defaults for RunPod and local server runs.
# Secrets such as HF_TOKEN must be set in RunPod environment variables.
#
# When using the curl bootstrap command, APP_REPO_URL, APP_REPO_REF, APP_DIR,
# and APP_PERSIST_ROOT must still come from the RunPod template because this
# file is not available until after the repository has been cloned.

APP_MANAGED_SERVICES=1
APP_UPDATE_MODE=reset
APP_INSTALL_EXTRAS=reconstruction,vggt,segmentation
APP_REFRESH_MODEL_CACHE=0
APP_PREPARE_VGGT=0
APP_PREFETCH_VGGT=0
APP_PREPARE_RECONVIAGEN=1
APP_PREFETCH_RECONVIAGEN=1

RECONVIAGEN_PRELOAD=1
RECONVIAGEN_MAX_IMAGES=6
RECONVIAGEN_PIPELINE_TYPE=1024_cascade
RECONVIAGEN_SS_SOURCE=mesh
RECONVIAGEN_LOW_VRAM=1
RECONVIAGEN_TEXTURE_SIZE=2048
RECONVIAGEN_DECIMATION_TARGET=500000
RECONVIAGEN_WORKER_RESTART=1
RECONVIAGEN_WORKER_RESTART_DELAY_SECONDS=20

VGGT_MAX_IMAGES=12
VGGT_PRELOAD=0
VGGT_AS_FINAL=0
VGGT_EMPTY_CACHE_AFTER_RUN=0

SCAN_MAX_FRAMES=24
SCAN_STRIDE=4
SCAN_FRAME_WORKERS=4
SCAN_RUN_TSDF=0
MESH_METHOD=printable_metric

OBJECT_MASK_BACKEND=sam3_depth
OBJECT_SAM_MODEL=sam3.pt
OBJECT_SAM_MAX_FRAMES=3
OBJECT_MASK_PROPAGATION=1
OBJECT_PROPAGATION_ANCHORS=2
OBJECT_PROPAGATION_DEPTH_TOLERANCE_METERS=0.08
OBJECT_CENTER_FRACTION=0.35
OBJECT_DEPTH_BAND_METERS=0.45
OBJECT_MIN_MASK_RATIO=0.002
OBJECT_MAX_MASK_RATIO=0.65
OBJECT_REMOVE_DOMINANT_PLANE=1
OBJECT_PLANE_DISTANCE_METERS=0.025
OBJECT_PLANE_SAMPLE_STRIDE=4

OBJECT_TSDF_VOXEL_METERS=0.004
OBJECT_TSDF_TRUNC_METERS=0.02
OBJECT_TSDF_DEPTH_TRUNC_METERS=4.0
OBJECT_MESH_SMOOTH_ITERATIONS=3
OBJECT_MESH_SMOOTH_METHOD=taubin

OBJECT_ALPHA_NEIGHBOR_FACTOR=8.0
OBJECT_ALPHA_MIN_EXTENT_FRACTION=0.12
OBJECT_ALPHA_MAX_EXTENT_FRACTION=0.5
OBJECT_PRINTABLE_SMOOTH_ITERATIONS=2
OBJECT_PRINTABLE_SUBDIVISION_ITERATIONS=1
OBJECT_PRINTABLE_TRIM_PERCENT=1.0

OBJECT_TEMPORAL_FILTER=1
OBJECT_TEMPORAL_VOXEL_METERS=0.006
OBJECT_TEMPORAL_MIN_FRAMES=2

POINT_CLOUD_CLEANUP=1
OBJECT_POINT_CLOUD_VOXEL_METERS=0
SCENE_POINT_CLOUD_VOXEL_METERS=0
POINT_CLOUD_OUTLIER_NEIGHBORS=20
POINT_CLOUD_OUTLIER_STD_RATIO=1.5
POINT_CLOUD_RADIUS_FACTOR=4.0
POINT_CLOUD_RADIUS_MIN_NEIGHBORS=3

AI_ICP_ITERATIONS=20
AI_ICP_MAX_DISTANCE_METERS=0.03
AI_PRINT_VOXEL_REPAIR=1
AI_PRINT_VOXEL_METERS=0.0015
